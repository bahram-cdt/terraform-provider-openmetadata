# Example: Complete OpenMetadata configuration
#
# This example demonstrates all currently supported resource types.

terraform {
  required_providers {
    openmetadata = {
      source  = "open-metadata/openmetadata"
      version = "~> 0.1"
    }
  }
}

provider "openmetadata" {
  # Set via environment variables:
  #   OPENMETADATA_HOST  = "https://openmetadata.example.com"
  #   OPENMETADATA_TOKEN = "eyJhbG..."
}

# --- Teams ---

resource "openmetadata_team" "data_engineering" {
  name         = "DataEngineering"
  display_name = "Data Engineering"
  description  = "Owns ETL pipelines, data models, and data infrastructure."
  team_type    = "Group"
  is_joinable  = false
}

resource "openmetadata_team" "data_analytics" {
  name         = "DataAnalytics"
  display_name = "Data Analytics"
  description  = "Owns dashboards, reports, and ad-hoc analysis."
  team_type    = "Group"
  is_joinable  = true
}

# --- Classifications & Tags ---

resource "openmetadata_classification" "data_quality" {
  name               = "DataQuality"
  display_name       = "Data Quality"
  description        = "Tags for data quality status."
  mutually_exclusive = true
}

resource "openmetadata_tag" "verified" {
  name           = "Verified"
  classification = openmetadata_classification.data_quality.name
  description    = "Data has been verified and is production-ready."
}

resource "openmetadata_tag" "unverified" {
  name           = "Unverified"
  classification = openmetadata_classification.data_quality.name
  description    = "Data has not been verified yet."
}

resource "openmetadata_tag" "deprecated" {
  name           = "Deprecated"
  classification = openmetadata_classification.data_quality.name
  description    = "Data is deprecated and should not be used for new work."
}

# --- Glossary & Terms ---

resource "openmetadata_glossary" "business_glossary" {
  name               = "BusinessGlossary"
  display_name       = "Business Glossary"
  description        = "Core business terms and definitions."
  mutually_exclusive = false
}

resource "openmetadata_glossary_term" "customer" {
  glossary    = openmetadata_glossary.business_glossary.name
  name        = "Customer"
  description = "An organization or individual that has purchased or is evaluating our product."
  synonyms    = ["Client", "Account"]
}

resource "openmetadata_glossary_term" "mrr" {
  glossary    = openmetadata_glossary.business_glossary.name
  name        = "MRR"
  display_name = "Monthly Recurring Revenue"
  description = "The predictable total revenue generated by the business from all active subscriptions in a particular month."
}
