# OpenMetadata acceptance-test environment overrides.
#
# This file is loaded by docker compose alongside the official OpenMetadata
# docker-compose.yml (which already uses ${VAR:-default} for every setting).
# Only values that differ from the upstream defaults are listed here.
#
# HOW TO UPGRADE TO A NEW OM VERSION
# ────────────────────────────────────
# 1. Update OPENMETADATA_VERSION below.
# 2. Run:  ./scripts/update-test-compose.sh
#    This re-downloads the official docker-compose.yml from that release.
# 3. Commit both docker/test/docker-compose.yml and docker/test/.env.

# ── Version ───────────────────────────────────────────────────────────────────
OPENMETADATA_VERSION=1.12.4

# ── Heap reduction (saves ~1 GB on CI runners vs. the 2 GB upstream default) ──
OPENMETADATA_HEAP_OPTS=-Xmx1G -Xms1G
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ── Disable Airflow integration (not needed for provider tests) ───────────────
PIPELINE_SERVICE_CLIENT_ENABLED=false

# ── Reduce log noise in CI ─────────────────────────────────────────────────────
LOG_LEVEL=WARN
